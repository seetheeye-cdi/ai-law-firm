# Database (SQLite for local dev, no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./ai_law_firm.db
# For production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_law_firm

# Base URL (set to ngrok URL for Slack integration)
BASE_URL=http://localhost:8000

# Slack
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
LAWYER_NOTIFICATION_CHANNEL=C0123456789

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Auth (MVP)
API_KEY=your-api-key-here
# Lawyer API keys (JSON: {"key": "lawyer_name", ...})
LAWYER_API_KEYS={"lawyer-key-1": "김변호사", "lawyer-key-2": "이변호사"}
